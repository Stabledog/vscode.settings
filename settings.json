{
    "files.associations": {
        "*taskrc": "shellscript",
        "*.jrnl": "markdown"
    },
    "shebang.associations": [
        {
            "pattern": "^#!/bin/bash$",
            "language": "shellscript"
        },
        {
            "pattern": "^.* vim: filetype=sh :$",
            "language": "shellscript"
        }
    ],
    "files.eol": "\n",
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,
    "vim.easymotion": true,
    "vim.hlsearch": true,
    "vim.leader": ",",
    "vim.useSystemClipboard": true,
    "vim.searchHighlightColor": "#ff7b00a1",
    "terminal.integrated.cursorBlinking": true,
   
    "terminal.integrated.shell.windows": "c:\\cygwin\\bin\\bash.exe",
    "terminal.integrated.env.windows": {
        "CHERE_INVOKING": "1"
    },
    "vim.cursorStylePerMode.insert": "block-outline",
    "vim.cursorStylePerMode.normal": "block",
    "git.ignoreMissingGitWarning": true,
    "workbench.sideBar.location": "right",
    "workbench.colorCustomizations": {
        "window.activeBorder": "#00ff00",
        "window.inactiveBorder": "#ff0000",
    },

    "terminal.integrated.scrollback": 30000,
    "terminal.integrated.shellArgs.windows": [ "-l"],
    "terminal.integrated.shellArgs.linux": ["--rcfile","~/.wsl.rc"],

    "vim.handleKeys": {
        "<C-d>": true,
        "<C-w>": false
    },
    "vim.insertModeKeyBindings": [
        {
            "before":  ["j", "k"],
            "after": ["<Esc>"]
        }
    ],

    "vim.normalModeKeyBindingsNonRecursive": [
        {
            "before": ["s"],
            "commands": [":w"]
        },
        {
            "before": ["<leader>", "1"],
            "commands": ["editor.action.commentLine"]
        },
        {
            "before": ["<leader>", "n"],
            "commands": ["workbench.action.quickOpen"]
        },
        {
            "before": ["="],
            "commands": ["workbench.action.tasks.build"]
        },
        {
            "before": ["j"],
            "after": ["g","j"]
        },
        {
            "before": ["k"],
            "after": ["g","k"]
        }
    ],
    "editor.renderWhitespace": "none",
    "editor.renderControlCharacters": false,
    "liveServer.settings.donotVerifyTags": true,
    "python.jediEnabled": true,
    "breadcrumbs.enabled": true,
    "editor.minimap.enabled": false,
    "window.zoomLevel": 1,
    "materialTheme.accent": "Orange",
    "gitlens.statusBar.enabled": false,
    "gitlens.mode.statusBar.enabled": false,
    "gitlens.hovers.enabled": false,
    "gitlens.hovers.currentLine.details": false,
    "gitlens.hovers.currentLine.changes": false,
    "gitlens.hovers.avatars": false,
    "gitlens.hovers.currentLine.enabled": false,
    "gitlens.hovers.annotations.changes": false,
    "gitlens.hovers.annotations.enabled": false,
    "workbench.iconTheme": "material-icon-theme",
    "workbench.fontAliasing":"true",
    "gitlens.currentLine.enabled": false,
    "liveServer.settings.donotShowInfoMsg": true,
