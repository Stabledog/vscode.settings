	"shebang.associations": [
		{
			"pattern": "^#!/bin/bash$",
			"language": "shellscript"
		},
		{
			"pattern": "^.* vim: filetype=sh :$",
			"language": "shellscript"
		}
	],
	"terminal.integrated.cursorBlinking": true,
	"terminal.integrated.env.windows": {
		"CHERE_INVOKING": "1"
	},
	"terminal.integrated.scrollback": 30000,
	"terminal.integrated.shell.linux": "/bin/bash",
	"terminal.integrated.shell.windows": "c:\\cygwin\\bin\\bash.exe",
	"terminal.integrated.shellArgs.linux": [
		"--rcfile",
		"~/.wsl.rc"
	],
	"terminal.integrated.shellArgs.windows": [
		"-l"
	],
	"vim.cursorStylePerMode.insert": "block-outline",
	"vim.cursorStylePerMode.normal": "block",
	"vim.easymotion": true,
	"vim.handleKeys": {
		"<C-d>": true,
		"<C-w>": false
	},
	"vim.hlsearch": true,
	"vim.insertModeKeyBindings": [
		{
			"before": [
				"j",
				"k"
			],
			"after": [
				"<Esc>"
			]
		}
	],
	"vim.leader": ",",
	"vim.normalModeKeyBindingsNonRecursive": [
		{
			"before": [
				"s"
			],
			"commands": [
				":w"
			]
		},
		{
			"before": [
				"<leader>",
				"1"
			],
			"commands": [
				"editor.action.commentLine"
			]
		},
		{
			"before": [
				"<leader>",
				"n"
			],
			"commands": [
				"workbench.action.quickOpen"
			]
		},
		{
			"before": [
				"="
			],
			"commands": [
				"workbench.action.tasks.build"
			]
		},
		{
			"before": [
				"j"
			],
			"after": [
				"g",
				"j"
			]
		},
		{
			"before": [
				"k"
			],
			"after": [
				"g",
				"k"
			]
		}
	],
	"vim.searchHighlightColor": "#ff7b00a1",
	"vim.useSystemClipboard": true,
	"window.zoomLevel": 2,
	"wordcounter.count_chars": false,
	"wordcounter.count_paragraphs": false,
	"wordcounter.include_eol_chars": false,
	"wordcounter.wpm": 110,
	"workbench.colorCustomizations": {
